# Database
DATABASE_URL="postgresql://user:password@localhost:5432/krushiva"
DIRECT_URL="postgresql://user:password@localhost:5432/krushiva"

# Supabase (production)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_PORT=3001
NODE_ENV="development"

# SMS (MSG91 or Twilio)
SMS_PROVIDER="msg91"
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_SENDER_ID="KRSIVA"
MSG91_TEMPLATE_ID="your-template-id"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@krushiva.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Krushiva <noreply@krushiva.com>"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# File Storage (Supabase Storage)
STORAGE_BUCKET="krushiva-files"
MAX_FILE_SIZE_MB=10

# WhatsApp (optional Phase 2)
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""

# Security
CORS_ORIGINS="http://localhost:3000,https://krushiva.com"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
